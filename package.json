{
  "name": "skillrisk",
  "version": "0.1.0",
  "description": "Local-first risk checker for reusable agent skill instructions.",
  "main": "src/index.js",
  "bin": {
    "skillrisk": "src/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/index.js && node --check src/cli.js",
    "smoke": "node src/cli.js fixtures/safe-skill.md",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "local-first",
    "dry-run"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/skillrisk.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/skillrisk/issues"
  },
  "homepage": "https://github.com/rogerchappel/skillrisk#readme",
  "author": "Roger Chappel",
  "license": "MIT",
  "files": [
    "src",
    "fixtures",
    "docs",
    "scripts",
    "CHANGELOG.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "SKILL.md"
  ]
}
